{
  "name": "@finishkit/mcp",
  "version": "0.3.3",
  "mcpName": "io.github.FinishKit/mcp",
  "description": "MCP server for FinishKit. Production readiness scanner for AI-built apps. Enables AI agents in Claude, Cursor, Windsurf, and VS Code to check if code is ready to ship.",
  "homepage": "https://finishkit.app",
  "author": "FinishKit <support@finishkit.app>",
  "bugs": {
    "url": "https://github.com/FinishKit/mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FinishKit/mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "finishkit",
    "security",
    "security-scanning",
    "vulnerability-scanner",
    "code-review",
    "deployment",
    "deployment-checker",
    "ci-cd",
    "static-analysis",
    "ai-tools",
    "llm-tools",
    "claude",
    "cursor",
    "windsurf",
    "copilot",
    "github",
    "typescript",
    "npm",
    "ai-agent",
    "vibe-coding",
    "production-ready",
    "launch-readiness",
    "ship-ready",
    "finish-plan",
    "production-readiness"
  ],
  "license": "MIT",
  "bin": {
    "finishkit-mcp": "./bin/finishkit-mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "smithery.yaml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/setup-cli.ts src/login-cli.ts src/logout-cli.ts --format cjs --dts --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@finishkit/sdk": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.0.0"
  }
}
